# LatticeBio — Environment Variables
# Copy this file to ../.env (project root) and fill in your values.

# ---------------------------------------------------------------------------
# OpenAI API (primary LLM)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here

# Model for NER entity extraction (default: gpt-4o-mini for speed/cost)
# OPENAI_NER_MODEL=gpt-4o-mini

# Model for agent reasoning (default: gpt-4o-mini)
# OPENAI_AGENT_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite (default — zero config, local dev):
DATABASE_URL=sqlite+aiosqlite:///./biostream.db
#
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/biostream

# ---------------------------------------------------------------------------
# Task queue (optional)
# ---------------------------------------------------------------------------
# Leave blank to use FastAPI BackgroundTasks (single-process, dev mode).
# Set to a Redis URL to enable Celery workers.
REDIS_URL=

# ---------------------------------------------------------------------------
# BioStudies API
# ---------------------------------------------------------------------------
BIOSTUDIES_TIMEOUT=30
PIPELINE_QUERY=cancer
PIPELINE_PAGE_SIZE=10

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# PORT=8000
