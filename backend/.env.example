# BioStream Backend — Environment Variables
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# Database (Option A)
# ---------------------------------------------------------------------------
# SQLite (default — zero config, local dev):
# DATABASE_URL=sqlite+aiosqlite:///./biostream.db
#
# PostgreSQL (production — Supabase or AWS RDS):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/biostream
DATABASE_URL=sqlite+aiosqlite:///./biostream.db

# ---------------------------------------------------------------------------
# Task queue (Option B)
# ---------------------------------------------------------------------------
# Leave blank to use FastAPI BackgroundTasks (single-process, dev mode).
# Set to a Redis URL to enable Celery workers (multi-process, production).
#
# Start a worker after setting this:
#   celery -A celery_app.celery_app worker --loglevel=info --concurrency=2
REDIS_URL=

# ---------------------------------------------------------------------------
# Local SLM (Ollama)
# ---------------------------------------------------------------------------
# Model to use for biomedical NER. llama3.2:3b is the recommended baseline.
# Pull it first: ollama pull llama3.2:3b
# OLLAMA_MODEL=llama3.2:3b

# ---------------------------------------------------------------------------
# BioStudies API
# ---------------------------------------------------------------------------
# HTTP timeout (seconds) for BioStudies API requests
BIOSTUDIES_TIMEOUT=30

# Default search query used by the pipeline ingestion
PIPELINE_QUERY=cancer

# Number of studies to fetch per pipeline run
PIPELINE_PAGE_SIZE=10

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# PORT=8000
